            const now = Date.now();
            try {
              localStorage.setItem(STORE_KEY, String(n));
              localStorage.setItem(STORE_TS, String(now));
            } catch (e) {}
            statusEl.textContent = formatStatus(now);
            return true;
          }
        } catch (e) {}
      }
      return false;
    }
    tryFetch();
  })();

  document.querySelectorAll('.filter').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.filter').forEach(x => x.classList.remove('is-on'));
      b.classList.add('is-on');
      const f = b.dataset.f;
      document.querySelectorAll('.rev').forEach(r => {
        const cats = (r.dataset.cat || '').split(' ');
        r.style.display = (f === 'all' || cats.includes(f)) ? '' : 'none';
      });
    });
  });
</script>

</Base>

