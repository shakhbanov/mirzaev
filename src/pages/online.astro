---
import Base from '~/layouts/Base.astro';
---

<Base title={`Онлайн-консультация уролога · 3 500 ₽ — доктор Мирзаев, Ростов`} description={`Онлайн-консультация уролога Мирзаева — 3 500 ₽. Видеоконсультация 30–45 минут (Zoom/WhatsApp), изучение анализов до встречи, письменное заключение, переписка 14 дней. Запись на сайте.`}>

  <Fragment slot="head">
